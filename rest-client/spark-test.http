@url = https://api.dfx.swiss/v1
@sparkAddress = YOUR_SPARK_ADDRESS
@signature = YOUR_SIGNATURE

// ============================================================
// STEP 1: Get sign message for Spark address
// ============================================================

# @name signMessage
GET {{url}}/auth/signMessage?address={{sparkAddress}}

###

// ============================================================
// STEP 2: Sign in with Spark signature
// Sign the message from Step 1 using:
//   npx ts-node scripts/spark-test-helper.ts sign "THE_MESSAGE"
// Then paste the signature above in @signature
// ============================================================

# @name login
POST {{url}}/auth/signIn
content-type: application/json

{
    "address": "{{sparkAddress}}",
    "signature": "{{signature}}"
}

###

// ============================================================
// STEP 3: Query Spark balance (auth required)
// ============================================================

@authToken = {{login.response.body.accessToken}}

POST {{url}}/blockchain/balances
content-type: application/json
Authorization: Bearer {{authToken}}

{
    "address": "{{sparkAddress}}",
    "blockchain": "Spark"
}

###

// ============================================================
// STEP 4: Verify a Spark signature (no auth required)
// ============================================================

# @name verifySignature
GET {{url}}/auth/verifySignature?address={{sparkAddress}}&message=test_message&signature={{signature}}

###

// ============================================================
// STEP 5: Sign up new user with Spark (if not registered yet)
// ============================================================

# @name signup
POST {{url}}/auth/signUp
content-type: application/json

{
    "address": "{{sparkAddress}}",
    "signature": "{{signature}}"
}

###
